{
  "name": "opalfarm-dashboard",
  "version": "1.1.0",
  "private": true,
  "description": "Local-first GL.iNet Opal and Android operations dashboard for Windows",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "start:desktop": "electron .",
    "test:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\test-phonefarm-smoke.ps1",
    "dist:desktop": "electron-builder --win portable nsis --x64"
  },
  "build": {
    "appId": "com.opalfarm.desktop",
    "productName": "OpalFarm",
    "artifactName": "${productName} ${version}.${ext}",
    "files": [
      "assets/**/*",
      "electron/**/*",
      "web/**/*",
      "scripts/**/*",
      "android/**/*",
      "config/**/*",
      "server.js",
      "package.json",
      "README.md"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "assets/phonefarm.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "installerIcon": "assets/phonefarm.ico",
      "uninstallerIcon": "assets/phonefarm.ico",
      "installerHeaderIcon": "assets/phonefarm.ico",
      "shortcutName": "OpalFarm",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^24.13.3"
  }
}
